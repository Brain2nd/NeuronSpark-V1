\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Biological interpretability analysis of \textsc  {NeuronSpark}{}-0.9B-Chat on Chinese text (token labels shown in pinyin transliteration). \textbf  {(a)}~Per-token E[K] for the sentence ``The capital of China is Beijing, located in the northern part of the North China Plain''; punctuation tokens (red) receive notably fewer SNN steps than content words. \textbf  {(b)}~E[K] grouped by part-of-speech category (jieba Chinese POS tagger, 40 test sentences); function words and punctuation allocate $\sim $0.7 fewer steps than nouns, verbs, and adjectives. \textbf  {(c)}~Per-layer E[K] for SNNBlock vs.\ SNNFFN; Block E[K] increases monotonically in deeper layers (up to 12.7 at L19), while FFN E[K] remains stable around 7--8. \textbf  {(d)}~Distribution of learned $\beta $ (membrane decay rate) across all 143,360 hidden neurons; 67.3\% are fast-responding ($\beta < 0.9$) and 32.7\% are slow-memory neurons.}}{13}{figure.caption.33}\protected@file@percent }
\newlabel{fig:interpretability}{{4}{13}{Biological interpretability analysis of \model {}-0.9B-Chat on Chinese text (token labels shown in pinyin transliteration). \textbf {(a)}~Per-token E[K] for the sentence ``The capital of China is Beijing, located in the northern part of the North China Plain''; punctuation tokens (red) receive notably fewer SNN steps than content words. \textbf {(b)}~E[K] grouped by part-of-speech category (jieba Chinese POS tagger, 40 test sentences); function words and punctuation allocate $\sim $0.7 fewer steps than nouns, verbs, and adjectives. \textbf {(c)}~Per-layer E[K] for SNNBlock vs.\ SNNFFN; Block E[K] increases monotonically in deeper layers (up to 12.7 at L19), while FFN E[K] remains stable around 7--8. \textbf {(d)}~Distribution of learned $\beta $ (membrane decay rate) across all 143,360 hidden neurons; 67.3\% are fast-responding ($\beta < 0.9$) and 32.7\% are slow-memory neurons}{figure.caption.33}{}}
\@writefile{toc}{\contentsline {paragraph}{Computation allocation is structural, not predictive.}{13}{section*.34}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Surprisal vs.\ E[K] analysis (40 Chinese sentences, 541 tokens). \textbf  {(a)}~Scatter plot: BOS tokens (red crosses) dominate the apparent negative correlation ($r{=}{-}0.50$); excluding them yields $r{=}{-}0.12$ (blue line). \textbf  {(b)}~Mean E[K] binned by surprisal range (excluding BOS): E[K] is flat across all bins, confirming that computation allocation is independent of predictive difficulty.}}{14}{figure.caption.35}\protected@file@percent }
\newlabel{fig:surprisal}{{5}{14}{Surprisal vs.\ E[K] analysis (40 Chinese sentences, 541 tokens). \textbf {(a)}~Scatter plot: BOS tokens (red crosses) dominate the apparent negative correlation ($r{=}{-}0.50$); excluding them yields $r{=}{-}0.12$ (blue line). \textbf {(b)}~Mean E[K] binned by surprisal range (excluding BOS): E[K] is flat across all bins, confirming that computation allocation is independent of predictive difficulty}{figure.caption.35}{}}
\@writefile{toc}{\contentsline {paragraph}{Reasoning capability assessment.}{14}{section*.36}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Reasoning capability assessment (28 questions). \textbf  {(a)}~Accuracy by category: arithmetic 0\%, logic 83\% (superficial), commonsense 25\%, coherence 6/6. \textbf  {(b)}~E[K] and surprisal are flat across categories, indicating no adaptive computation increase for harder tasks. The model has learned structural language patterns but not reasoning.}}{14}{figure.caption.37}\protected@file@percent }
\newlabel{fig:reasoning}{{6}{14}{Reasoning capability assessment (28 questions). \textbf {(a)}~Accuracy by category: arithmetic 0\%, logic 83\% (superficial), commonsense 25\%, coherence 6/6. \textbf {(b)}~E[K] and surprisal are flat across categories, indicating no adaptive computation increase for harder tasks. The model has learned structural language patterns but not reasoning}{figure.caption.37}{}}
